# Google OAuth client for Drive sync (docs/13). Copy to .env and fill in.
# Create a Desktop OAuth client in Google Cloud Console with the Drive API
# enabled and the consent screen published "In production" (Testing mode expires
# refresh tokens after 7 days). Until these are set, the Settings > Sync section
# shows "Google client not configured" and the sign-in button is disabled.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=
