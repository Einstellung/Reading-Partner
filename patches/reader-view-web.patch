diff --git a/src/index.view-web.js b/src/index.view-web.js
new file mode 100644
index 0000000..ea56e33
--- /dev/null
+++ b/src/index.view-web.js
@@ -0,0 +1,17 @@
+import View from './common/view';
+
+// Production "web View" entry: exposes a thin window.createView() that hands
+// full control of options/callbacks to the host page (our shell), mirroring how
+// index.web.js exposes window.createReader(). No demo auto-loading, no chrome.
+window.createView = (options) => {
+	if (window._view) {
+		throw new Error('View is already initialized');
+	}
+	let view = new View({
+		// Default mount point matches index.view.html; host may override.
+		container: document.getElementById('view'),
+		...options,
+	});
+	window._view = view;
+	return view;
+};
